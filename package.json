{
  "name": "solana-data-farmer-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node dist/server.js",
    "migrate": "NODE_ENV=production tsx src/db/migrate.ts",
    "sync": "NODE_ENV=production tsx src/workers/syncOnce.ts",
    "worker": "NODE_ENV=production tsx src/workers/syncLoop.ts"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "mysql2": "^3.11.5",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.7.2"
  }
}
