PORT=3000
LOG_LEVEL=info

# Set this in production. When present, /api routes require x-api-key or Bearer auth.
API_KEY=
CORS_ORIGIN=*

# Use a paid Solana RPC provider for production indexing. The public RPC is fine for light testing.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_COMMITMENT=confirmed
SYNC_BATCH_LIMIT=50
SYNC_INTERVAL_MS=60000
ENABLE_SYNC_LOOP=false

# Railway MySQL commonly provides the MYSQL* variables below.
# You can also use MYSQL_URL or DATABASE_URL with a mysql:// URI.
MYSQL_URL=
DATABASE_URL=
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=
